# TrenATiempo — Variables de Entorno
# Copia este fichero como .env.local y rellena los valores
# NUNCA subas .env.local a Git

# ─── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Solo para Route Handlers y scripts de servidor. NUNCA exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Web Push / VAPID ──────────────────────────────────────────────────────────
# Generar con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BM...
VAPID_PRIVATE_KEY=xxx...
VAPID_MAILTO=admin@trenatiempo.app

# ─── Cron Jobs ─────────────────────────────────────────────────────────────────
# Secreto para proteger los cron jobs de Vercel
# Generar con: openssl rand -hex 32
CRON_SECRET=your-random-secret-here

# ─── Analytics ────────────────────────────────────────────────────────────────
# ID del contenedor de Google Tag Manager (ej: GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── ADIF / Renfe API ──────────────────────────────────────────────────────────
# TTL de caché en segundos (300 = 5 min para horarios)
ADIF_CACHE_TTL_HORARIOS=300
ADIF_CACHE_TTL_ESTACIONES=86400

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
API_RATE_LIMIT_RPM=60

# ─── E2E Tests ─────────────────────────────────────────────────────────────────
# Credenciales de prueba para tests E2E (solo desarrollo)
E2E_ADMIN_EMAIL=admin@trenatiempo.com
E2E_ADMIN_PASSWORD=your-test-password
E2E_USER_EMAIL=user@trenatiempo.com
E2E_USER_PASSWORD=your-test-password

# ─── Entorno ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
