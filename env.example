# RodaRail — Variables de Entorno
# Copia este fichero como .env.local y rellena los valores
# NUNCA subas .env.local a Git

# ─── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Solo para Route Handlers y scripts de servidor. NUNCA exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Web Push / VAPID ──────────────────────────────────────────────────────────
# Generar con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BM...
VAPID_PRIVATE_KEY=xxx...
VAPID_MAILTO=admin@rodarail.app

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=RodaRail

# ─── ADIF / Renfe API ──────────────────────────────────────────────────────────
# TTL de caché en segundos (300 = 5 min para horarios)
ADIF_CACHE_TTL_HORARIOS=300
ADIF_CACHE_TTL_ESTACIONES=86400

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
API_RATE_LIMIT_RPM=60

# ─── Entorno ───────────────────────────────────────────────────────────────────
NODE_ENV=development
